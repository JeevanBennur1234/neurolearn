# =========================================
# NeuroLearn-GEN Environment Configuration
# =========================================

# --- LLM BACKEND (choose one) ---
LLM_PROVIDER=gemini                     # Options: gemini | openai | groq | ollama

# Gemini (Free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash           # or gemini-1.5-pro

# OpenAI (if switching)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Groq (Free tier, very fast)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Ollama (fully local, free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- RAG Config ---
VECTOR_STORE=chroma                     # Options: chroma | faiss
CHROMA_PERSIST_DIR=./data/chroma_db
FAISS_INDEX_PATH=./data/faiss_index

# --- Intent Classifier ---
INTENT_MODEL=sentence-transformers/all-MiniLM-L6-v2
INTENT_CONFIDENCE_THRESHOLD=0.65

# --- App Config ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
MAX_CONTEXT_TOKENS=4096
